# Master encryption key — 32 bytes hex (64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=

# Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com

# Redis (for BullMQ scheduler)
REDIS_URL=redis://localhost:6379

# LLM API Keys (Gemini primary, OpenAI fallback)
LLM_KEY_1=
LLM_KEY_2=
LLM_KEY_3=
LLM_KEY_4=
LLM_KEY_5=

# LLM Provider config
LLM_PRIMARY_PROVIDER=gemini
LLM_PRIMARY_MODEL=gemini-pro
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=gpt-4

# Server
PORT=4000
WS_PORT=4001
